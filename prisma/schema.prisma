generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum InquiryStatus {
  NEW
  CONTACTED
  REVIEWING
  CLOSED
}

enum UserRole {
  ADMIN
  EDITOR
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String?
  summary    String
  adminEmail String
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([entity, createdAt])
}

model Inquiry {
  id                String        @id @default(cuid())
  name              String
  country           String
  phone             String
  email             String
  treatmentInterest String
  message           String
  status            InquiryStatus @default(NEW)
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([treatmentInterest])
}

model Hospital {
  id             String              @id @default(cuid())
  name           String
  slug           String              @unique
  city           String
  country        String              @default("India")
  overview       String
  accreditations Json
  departments    Json
  facilities     Json
  images          Json
  googleReviewUrl String?
  websiteUrl      String?
  contactEmail   String
  contactPhone   String
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  doctors            Doctor[]
  hospitalTreatments HospitalTreatment[]

  @@index([city])
  @@index([name])
}

model Doctor {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  imageUrl        String
  googleReviewUrl String?
  websiteUrl      String?
  specialization  String
  experienceYears Int
  city            String
  languages       Json
  education       String
  certifications  Json
  biography       String
  patientReviews  Json
  consultationFee Int?
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  doctorTreatments DoctorTreatment[]
  testimonials     Testimonial[]

  @@index([specialization])
  @@index([city])
  @@index([hospitalId])
}

model Treatment {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  category       String
  images         Json?
  procedure      String
  recovery       String
  costMin        Int
  costMax        Int
  currency       String   @default("USD")
  faqs           Json
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  doctorTreatments   DoctorTreatment[]
  hospitalTreatments HospitalTreatment[]
  testimonials       Testimonial[]

  @@index([category])
  @@index([name])
}

model DoctorTreatment {
  doctorId    String
  treatmentId String

  doctor    Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@id([doctorId, treatmentId])
}

model HospitalTreatment {
  hospitalId  String
  treatmentId String

  hospital  Hospital  @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  treatment Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@id([hospitalId, treatmentId])
}

model BlogPost {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  excerpt          String
  content          String
  featuredImage    String
  category         String
  tags             Json
  authorName       String
  authorTitle      String
  published        Boolean  @default(false)
  publishedAt      DateTime?
  seoTitle         String?
  seoDescription   String?
  openGraphImage   String?
  schemaType       String   @default("Article")
  readTimeMinutes  Int      @default(6)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([published, publishedAt])
  @@index([category])
}

model Testimonial {
  id           String   @id @default(cuid())
  patientName  String
  country      String
  city         String?
  treatment    String
  comment      String
  rating       Int
  imageUrl     String?
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  doctorId    String?
  doctor      Doctor?    @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  treatmentId String?
  treatmentRef Treatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)

  @@index([isPublished, createdAt])
}


